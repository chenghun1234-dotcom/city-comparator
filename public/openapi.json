{
  "openapi": "3.0.0",
  "info": {
    "title": "Digital Nomad City Comparator API",
    "description": "Compare two cities for digital nomads based on weather, living costs, and safety. Includes a custom Nomad Score and flight booking deep links.",
    "version": "1.1.0"
  },
  "servers": [
    {
      "url": "https://city-comparator.vercel.app",
      "description": "Production Server (Vercel)"
    }
  ],
  "paths": {
    "/api/v1/compare": {
      "get": {
        "summary": "Compare two cities",
        "parameters": [
          {
            "name": "city1",
            "in": "query",
            "description": "Origin city code (e.g., ICN, NYC)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "ICN"
            }
          },
          {
            "name": "city2",
            "in": "query",
            "description": "Destination city code (e.g., BKK, LON)",
            "required": false,
            "schema": {
              "type": "string",
              "default": "BKK"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful comparison",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComparisonResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Missing or invalid RapidAPI Proxy Secret"
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "RapidAPIKey": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "RapidAPIKey": {
        "type": "apiKey",
        "name": "X-RapidAPI-Key",
        "in": "header"
      }
    },
    "schemas": {
      "ComparisonResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "meta": {
            "type": "object",
            "properties": {
              "request_id": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "currency": { "type": "string", "default": "USD" }
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "recommended_city": { "type": "string" },
              "reason": { "type": "string" }
            }
          },
          "data": {
            "type": "object",
            "properties": {
              "city1": { "$ref": "#/components/schemas/CityData" },
              "city2": { "$ref": "#/components/schemas/CityData" },
              "travel": {
                "type": "object",
                "properties": {
                  "min_price": { "type": "number", "description": "Cheapest flight price" },
                  "booking_link": { "type": "string", "description": "Affiliate booking link" },
                  "airline": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "CityData": {
        "type": "object",
        "properties": {
          "info": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "name": { "type": "string" },
              "nomad_score": { "type": "string" }
            }
          },
          "weather": {
            "type": "object",
            "properties": {
              "temperature": { "type": "number" },
              "weathercode": { "type": "number" }
            }
          },
          "metrics": {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            },
            "description": "Dynamic mapping of nomad metrics (Internet, Cost, Safety, etc.)"
          },
          "lodging": {
            "type": "object",
            "properties": {
              "price": { "type": "string" },
              "link": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
